# Environment Variables for Playwright Tests

# Set to 'true' when running in CI environment
# This affects retries, parallel workers, and other CI-specific behaviors
CI=false
FLIGHT_DEALS_URL=https://www.holidayfinder.co.il/?#adults=2&babies=0&budget=100,399&children=0&duration=1800&fromwhere=TLV&maxNights=3&minNights=2&nights=2,3&order=-1&rooms=1&sort=best&type=month&weekendsOnly=true&what=83

# Base URL for tests (uncomment and set if needed)
# BASE_URL=http://localhost:3000

# Browser configuration
# HEADLESS=true

# Test environment (dev, staging, prod)
# TEST_ENV=dev

# API endpoints or other config
# API_BASE_URL=https://api.example.com